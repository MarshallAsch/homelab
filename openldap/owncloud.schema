# ownCloud / Nextcloud LDAP schema (OID arc 1.3.6.1.4.1.39430 = ownCloud's IANA PEN).
# Provides ownCloudQuota (used as Nextcloud's LDAP "Quota Field") and ownCloudUUID.
# Loaded by osixia on FIRST init via the bootstrap schema dir; on an already-
# initialised directory it was added online to cn=config (persists in slapd.d).

attributetype ( 1.3.6.1.4.1.39430.1.1.1 NAME 'ownCloudQuota'
        DESC 'ownCloud user quota e.g. 2 GB'
        EQUALITY caseIgnoreMatch
        SUBSTR caseIgnoreSubstringsMatch
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.15 SINGLE-VALUE )

attributetype ( 1.3.6.1.4.1.39430.1.1.2 NAME 'ownCloudUUID'
        DESC 'ownCloud unique identifier'
        EQUALITY caseIgnoreMatch
        SUBSTR caseIgnoreSubstringsMatch
        SYNTAX 1.3.6.1.4.1.1466.115.121.1.15 SINGLE-VALUE )

objectclass ( 1.3.6.1.4.1.39430.1.2.1 NAME 'ownCloud'
        DESC 'ownCloud LDAP Schema'
        AUXILIARY
        MAY ( ownCloudQuota $ ownCloudUUID ) )
